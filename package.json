{
	"name": "root",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"dependencies": {
		"monaco-editor": "^0.53.0"
	},
	"scripts": {
		"lint": "biome lint",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx,json,html,css}": [
			"biome check --write"
		]
	},
	"pnpm": {
		"overrides": {
			"cipher-base": "1.0.7",
			"tar-fs": "1.16.6"
		},
		"packageExtensions": {
			"ibm_db": {
				"dependencies": {
					"node-gyp": "^11.5.0"
				}
			}
		},
		"onlyBuiltDependencies": [
			"argon2",
			"bcrypt",
			"cpu-features",
			"ibm_db",
			"oracledb",
			"ssh2"
		]
	}
