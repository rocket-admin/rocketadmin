{
	"compilerOptions": {
		"module": "NodeNext",
		"declaration": true,
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"allowJs": true,
		"esModuleInterop": true,
		"target": "ESNext",
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": "./",
		"incremental": true,
		"moduleResolution": "NodeNext",
		"skipLibCheck": true,
		"strict": false
	},
	// "references": [
	//   { "path": "../shared-code" },
	// ],
	"include": ["src", "test"],
	"exclude": ["node_modules", "dist", "../node_modules"]
}
